{
  "name": "farm-bundle-tracker",
  "private": true,
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "db:up": "docker compose up -d postgres",
    "db:down": "docker compose down",
    "db:reset": "docker compose down -v",
    "dev:backend": "DOTENV_CONFIG_PATH=../../.env npm run start:dev -w backend",
    "dev:frontend": "DOTENV_CONFIG_PATH=../../.env npm run dev -w frontend"
  },
  "dependencies": {
    "jsonwebtoken": "^9.0.3"
  },
  "devDependencies": {
    "@types/jsonwebtoken": "^9.0.10"
  }
}
